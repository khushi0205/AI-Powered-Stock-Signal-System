public with sharing class StockSignalController {

    @AuraEnabled(cacheable=true)
    public static Opportunity getSignal(Id recordId) {
        return [
            SELECT AI_Signal__c,
                   AI_Confidence__c,
                   AI_Reasoning__c,
                   Last_Analyzed__c,
                   Stock_Ticker__c
            FROM Opportunity
            WHERE Id = :recordId
            LIMIT 1
        ];
    }
}
